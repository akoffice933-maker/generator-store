# PostgreSQL. Use a least-privilege application user in production.
DATABASE_URL=postgresql://app_user:change-me@127.0.0.1:5432/generator_store

# Generate with: openssl rand -base64 48
AUTH_SECRET=replace-with-a-random-secret-of-at-least-32-characters

# Canonical public HTTPS URL. Required for CSRF origin checks and payment redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Railway Redis. Enables distributed rate limiting and the BullMQ outbox worker.
REDIS_URL=redis://default:change-me@127.0.0.1:6379
WORKER_CONCURRENCY=5

# Optional: enables card/SBP payment creation through YooKassa.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
